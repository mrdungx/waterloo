{
  "name": "lesson-publisher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:create": "tsx src/db/migrate.ts create",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.6",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "sanitize-html": "^2.14.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.12",
    "@types/sanitize-html": "^2.13.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
